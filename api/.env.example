# BeSQL API environment variables
# Copy this file to .env and fill in your values

# PostgreSQL connection string for the main application database
DATABASE_URL=postgresql://besql_app:change_me_in_production@localhost:5432/besql

# PostgreSQL connection string for the sandbox database (SQL execution)
SANDBOX_DATABASE_URL=postgresql://besql_sandbox:sandbox_password@localhost:5433/besql_sandbox

# JWT secret key — change this to a long random string in production
JWT_SECRET=change_me_to_a_long_random_secret_in_production

# JWT algorithm and token lifetimes
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,http://localhost:5500
