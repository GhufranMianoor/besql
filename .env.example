# API Keys and Secrets (Copy to .env and fill in real values)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anonymous_key
SUPABASE_KEY=your_anonymous_key
SUPABASE_SECRET=your_service_role_key

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/besql_db

# Application
NODE_ENV=development
PORT=3000

# Security
API_SECRET=change_me_to_secure_random_string
JWT_SECRET=change_me_to_secure_random_string

# CORS
CORS_ORIGIN=http://localhost:3000

# Third-party Services
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Feature Flags
ENABLE_ADMIN_PANEL=true
ENABLE_CUSTOM_CONTESTS=true
